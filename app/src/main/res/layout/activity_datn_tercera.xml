<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOMBRES:"
        tools:ignore="HardcodedText" />

    <EditText
        android:id="@+id/DATN_et_nombres_s3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:enabled="false"
        tools:ignore="Autofill,LabelFor,SpeakableTextPresentCheck,TextFields,TouchTargetSizeCheck,VisualLintTextFieldSize" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APELLIDOS:"
        tools:ignore="HardcodedText" />

    <EditText
        android:id="@+id/DATN_et_apellidos_s3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:enabled="false"
        tools:ignore="Autofill,LabelFor,SpeakableTextPresentCheck,TextFields,TouchTargetSizeCheck,VisualLintTextFieldSize" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRIMER NUMERO:"
        tools:ignore="HardcodedText" />

    <EditText
        android:id="@+id/DATN_et_primer_numero_s3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:enabled="true"
        android:inputType="number"
        tools:ignore="Autofill,LabelFor,SpeakableTextPresentCheck,TouchTargetSizeCheck,VisualLintTextFieldSize" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SEGUNDO NUMERO:"
        tools:ignore="HardcodedText" />

    <EditText
        android:id="@+id/DATN_et_segundo_numero_s3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:enabled="true"
        android:inputType="number"
        tools:ignore="Autofill,LabelFor,SpeakableTextPresentCheck,TouchTargetSizeCheck,VisualLintTextFieldSize" />

    <Button
        android:id="@+id/DATN_btn_cerrar_s3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar"
        tools:ignore="HardcodedText,VisualLintButtonSize" />

</LinearLayout>